# Copy to .env.local and fill in real values. .env.local is gitignored.

# --- Supabase (auth + database) ---
# Project URL and anon key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose this; used for admin/service operations.
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare R2 (file storage, S3-compatible) ---
# Endpoint is derived from the account id if R2_ENDPOINT is left blank:
#   https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
